# Copy to backend/.env and fill in values. .env is gitignored.

# --- LLM API keys ---
# Required for the real Claude agent. Without this, agent runs in dry mode (mock).
ANTHROPIC_API_KEY=

# Required for Gemini Robotics-ER (preview) and Gemini Pro Vision fallback.
GOOGLE_API_KEY=

# --- Sim endpoints (defaults assume local DAC sims with our port-collision patch) ---
DRONE_SIM_HTTP=http://localhost:8766
ROBOT_SIM_HTTP=http://localhost:8767

# --- Vision client selection ---
# One of: gemini_er, gemini_pro, claude_vision, mock
# `mock` is deterministic and used as demo-day insurance.
VLM_CLIENT=mock

# --- Agent config ---
# claude-sonnet-4-5 is the default; override here if needed.
CLAUDE_MODEL=claude-sonnet-4-5
AGENT_MAX_TOOL_CALLS=12

# --- Safety bounds (do not relax for demo) ---
SAFETY_MAX_MAGNITUDE=0.7
SAFETY_MAX_ACTIONS_PER_DISPATCH=12
SAFETY_DRONE_MIN_AGL_M=8
SAFETY_DRONE_MAX_AGL_M=80

# --- Demo / dev ---
LOG_LEVEL=INFO
ENABLE_CORS=true
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174

# Optional: where to teleport the drone on startup. Defaults to UC Davis.
DEMO_FIELD_LAT=38.5382
DEMO_FIELD_LON=-121.7617
DEMO_FIELD_ID=ucd_north_tomato
